{
  "name": "shopee-affiliate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "cd backend && pnpm run start:dev",
    "dev:frontend": "cd frontend && pnpm run dev",
    "build": "concurrently \"pnpm run build:backend\" \"pnpm run build:frontend\"",
    "build:backend": "cd backend && pnpm run build",
    "build:frontend": "cd frontend && pnpm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
