PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Primary – Shopee Web API (cookie-based).
# Login to affiliate.shopee.vn > DevTools (F12) > Network > copy the following
# request headers from a POST to /api/v3/gql?q=batchCustomLink:
SHOPEE_COOKIE=

# Security tokens – required for Shopee's WAF / anti-bot checks.
# These values change every session; copy them alongside the Cookie.
SHOPEE_CSRF_TOKEN=
SHOPEE_AF_AC_ENC_DAT=
SHOPEE_AF_AC_ENC_TOKEN=
SHOPEE_X_SAP_RI=
SHOPEE_X_SAP_SEC=

# Fallback – Manual redirect (fill in your affiliate publisher ID).
# Used automatically when SHOPEE_COOKIE is blank.
SHOPEE_AFFILIATE_ID=
SHOPEE_REDIRECT_BASE_URL=https://s.shopee.vn

LINK_HISTORY_FILE=storage/link-history.json
